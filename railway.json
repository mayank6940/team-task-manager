{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd frontend && npm install && npm run build"
  },
  "deploy": {
    "startCommand": "npx serve frontend/dist -l $PORT --config frontend/serve.json",
    "restartPolicyType": "ON_FAILURE"
  }
}