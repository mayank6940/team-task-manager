{
    admin off
}

:{$PORT} {
    # We try both potential locations for the dist folder
    root * /app/frontend/dist
    
    # Fallback to relative if /app/frontend/dist doesn't exist
    @not_absolute {
        not file {path}
    }
    handle @not_absolute {
        root * ./dist
    }

    file_server
    try_files {path} /index.html
}